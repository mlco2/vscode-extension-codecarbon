{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2020",
        "outDir": "out",
        "lib": ["ES2020"],
        "types": ["node", "vscode"],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true
    },
    "exclude": ["node_modules/**", "out/**"],
    "include": ["src/**/*.ts"]
}
