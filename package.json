{
  "name": "codecarbon",
  "displayName": "Codecarbon",
  "description": "Estimate and track carbon emissions from your computer, quantify and analyze their impact.",
  "version": "0.2.0",
  "preview": true,
  "pythonPackageInfo": {
    "name": "Codecarbon",
    "module": "codecarbon"
  },
  "publisher": "codecarbon",
  "license": "MIT",
  "homepage": "https://github.com/inimaz/vscode-extension-codecarbon",
  "repository": {
    "type": "git",
    "url": "https://github.com/inimaz/vscode-extension-codecarbon.git"
  },
  "bugs": {
    "url": "https://github.com/inimaz/vscode-extension-codecarbon/issues"
  },
  "galleryBanner": {
    "color": "#1e415e",
    "theme": "dark"
  },
  "icon": "images/logo-round.png",
  "keywords": [
    "python",
    "codecarbon",
    "carbon",
    "emissions",
    "environment",
    "sustainability",
    "climate"
  ],
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Machine Learning",
    "Other",
    "Data Science"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "properties": {
        "codecarbon.launchOnStartup": {
          "default": true,
          "description": "Launch the codecarbon tracker on startup.",
          "type": "boolean"
        },
        "codecarbon.interpreter": {
          "default": [],
          "description": "Python executable path. Leave empty to use system default.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      }
    },
    "commands": [
      {
        "title": "Start tracking emissions",
        "category": "Codecarbon",
        "command": "codecarbon.start"
      },
      {
        "title": "Stop tracking emissions",
        "category": "Codecarbon",
        "command": "codecarbon.stop"
      },
      {
        "title": "Check codecarbon version",
        "category": "Codecarbon",
        "command": "codecarbon.checkVersion"
      }
    ]
  },
  "scripts": {
    "compile": "tsc && cp -r src/scripts out",
    "watch": "tsc -watch",
    "lint": "eslint src",
    "package": "vsce package",
    "test:python": "python3 -m unittest discover -s tests/python -p \"test_*.py\"",
    "test:ts": "tsc -p tsconfig.tests.json && node --test out-tests/tests/ts/*.test.js",
    "test": "npm run test:python && npm run test:ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
